{
  "name": "apple-mcp-extended",
  "version": "0.1.0",
  "description": "Extended MCP server for Apple Contacts (fork of @griches/apple-contacts-mcp) with full field support and group safety",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "apple-contacts-extended": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test:roundtrip": "tsx scripts/roundtrip-test.ts"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  },
  "license": "MIT"
}
