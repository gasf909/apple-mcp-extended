{
  "name": "@gasf030304/apple-contacts-extended",
  "version": "0.4.1",
  "description": "Extended MCP server for Apple Contacts on macOS (fork of @griches/apple-contacts-mcp) with full field support, id-based safe matching, and ALLOWED_GROUPS safety",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "apple-contacts-extended": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.js.map",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test:roundtrip": "tsx scripts/roundtrip-test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "apple",
    "contacts",
    "macos",
    "applescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gasf909/apple-mcp-extended.git",
    "directory": "contacts"
  },
  "homepage": "https://github.com/gasf909/apple-mcp-extended/tree/main/contacts",
  "bugs": {
    "url": "https://github.com/gasf909/apple-mcp-extended/issues"
  },
  "os": ["darwin"],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3"
  },
  "license": "MIT"
}
